rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio Gallery rule
    match /portfolio_gallery/{itemId} {
      allow read: if true;
      allow create, update: if request.resource.data.title is string 
        && request.resource.data.category is string
        && request.resource.data.url is string
        && request.resource.data.description is string;
      allow delete: if true;
    }

    // Gallery Config rule
    match /gallery_config/{docId} {
      allow read, write: if true;
    }

    // Salon Config rule
    match /salon_config/{docId} {
      allow read, write: if true;
    }

    // Admin Credentials rule
    match /admin_credentials/{docId} {
      allow read: if true;
      allow write: if false; // prevent changes from outside
    }
  }
}
